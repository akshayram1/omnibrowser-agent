{
  "name": "@akshayram1/omnibrowser-agent",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "main": "./dist/lib.js",
  "module": "./dist/lib.js",
  "types": "./dist/types/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/lib/index.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "description": "Local-first OmniBrowser Agent (WebLLM + page automation)",
  "author": "Akshay Chame",
  "license": "MIT",
  "scripts": {
    "build": "node scripts/build.mjs && npm run build:types",
    "build:types": "tsc -p tsconfig.lib.json",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "node --experimental-strip-types --test src/shared/safety.test.ts src/core/planner.test.ts"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.322",
    "@types/node": "^25.5.0",
    "esbuild": "^0.25.2",
    "typescript": "^5.8.2"
  }
}
